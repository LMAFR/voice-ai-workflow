# Optional SMTP config for the access-failure email alert.
# If unset, alerts are appended to vps_backend/alerts.log instead of emailed.
# For Gmail: create an App Password (https://myaccount.google.com/apppasswords)
# and use it as SMTP_PASS (your normal password will NOT work).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alejandrofloridoreyes@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=alejandrofloridoreyes@gmail.com
ALERT_EMAIL=alejandrofloridoreyes@gmail.com

# Shared secret for the iPhone/Siri HTTP endpoint (issue_api.py). REQUIRED to run
# it. Make it long and random, e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`.
# The iOS Shortcut sends this in the JSON body; the GitHub token never leaves the VPS.
VOICE_ISSUE_API_SECRET=generate_a_long_random_string_here

# Per-repo tokens for THIRD-PARTY repos (optional). The default GH_TOKEN serves any
# repo listed as a plain "owner/name" string in vps_config.json. For a repo that needs
# a different token, reference it here by the name you put in vps_config.json's
# "token_env", e.g. {"repo": "someorg/their-repo", "token_env": "THEIR_REPO_TOKEN"}.
# Scope each to a SINGLE repo, Issues + Pull requests: Read & write only. Keep .env 600.
# THEIR_REPO_TOKEN=github_pat_xxx_scoped_to_their_repo_only
