# Optional SMTP config for the access-failure email alert.
# If unset, alerts are appended to vps_backend/alerts.log instead of emailed.
# For Gmail: create an App Password (https://myaccount.google.com/apppasswords)
# and use it as SMTP_PASS (your normal password will NOT work).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alejandrofloridoreyes@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=alejandrofloridoreyes@gmail.com
ALERT_EMAIL=alejandrofloridoreyes@gmail.com
